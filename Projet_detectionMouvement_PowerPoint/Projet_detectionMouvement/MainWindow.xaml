<Window x:Class="Projet_detectionMouvement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GESTURA APP"
        Height="720" Width="1280"
        Background="#050D15"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DropShadowEffect x:Key="NeonGlow"    BlurRadius="12" Color="#00FFFF" ShadowDepth="0" Opacity="0.85"/>
        <DropShadowEffect x:Key="MagentaGlow" BlurRadius="10" Color="#FF00FF" ShadowDepth="0" Opacity="0.85"/>
        <DropShadowEffect x:Key="GreenGlow"   BlurRadius="8"  Color="#00FF88" ShadowDepth="0" Opacity="0.9"/>
        <DropShadowEffect x:Key="RedGlow"     BlurRadius="10" Color="#FF3060" ShadowDepth="0" Opacity="0.9"/>

        <Style x:Key="FuturisticButton" TargetType="Button">
            <Setter Property="Background"       Value="#1100FFFF"/>
            <Setter Property="BorderBrush"      Value="#00FFFF"/>
            <Setter Property="Foreground"       Value="#00FFFF"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="22,9"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Effect"           Value="{StaticResource NeonGlow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#2200FFFF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FF00FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background"       Value="#22FF0044"/>
            <Setter Property="BorderBrush"      Value="#FF3060"/>
            <Setter Property="Foreground"       Value="#FF3060"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="22,9"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FontFamily"       Value="Consolas"/>
            <Setter Property="FontWeight"       Value="Bold"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Effect"           Value="{StaticResource RedGlow}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44FF0044"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="62"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0A000D18"
                BorderBrush="#1A00FFFF"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="310"/>
                </Grid.ColumnDefinitions>

                <Canvas Grid.Column="0">
                    <Rectangle Canvas.Left="14" Canvas.Top="10"  Width="2"  Height="24" Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Left="14" Canvas.Top="10"  Width="18" Height="2"  Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Left="14" Canvas.Top="44"  Width="2"  Height="14" Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Left="14" Canvas.Top="56"  Width="18" Height="2"  Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <TextBlock Canvas.Left="38" Canvas.Top="10"  Text="OPERATOR"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="9" Opacity="0.55"/>
                    <TextBlock Canvas.Left="38" Canvas.Top="22"  Text="FABRICE KOUAKOU"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                               Effect="{StaticResource NeonGlow}"/>
                    <TextBlock Canvas.Left="38" Canvas.Top="41"  Text="DÉVELOPPEUR NUMÉRIQUE"
                               Foreground="#FF00FF" FontFamily="Consolas" FontSize="10"
                               Effect="{StaticResource MagentaGlow}"/>
                </Canvas>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Ellipse Width="9" Height="9" Fill="#00FFFF" VerticalAlignment="Center"
                                 Margin="0,0,14,0" Effect="{StaticResource NeonGlow}"/>
                        <TextBlock Text="GESTURA  APP"
                                   Foreground="#00FF99" FontFamily="Consolas"
                                   FontSize="22" FontWeight="Bold"
                                   Effect="{StaticResource NeonGlow}"/>
                        <Ellipse Width="9" Height="9" Fill="#00FFFF" VerticalAlignment="Center"
                                 Margin="14,0,0,0" Effect="{StaticResource NeonGlow}"/>
                    </StackPanel>
                </StackPanel>

                <Canvas Grid.Column="2">
                    <Rectangle Canvas.Right="14" Canvas.Top="10"  Width="2"  Height="24" Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Right="14" Canvas.Top="10"  Width="18" Height="2"  Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Right="14" Canvas.Top="44"  Width="2"  Height="14" Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <Rectangle Canvas.Right="14" Canvas.Top="56"  Width="18" Height="2"  Fill="#00FFFF" Opacity="0.9" Effect="{StaticResource NeonGlow}"/>
                    <StackPanel Canvas.Right="36" Canvas.Top="16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="7" Height="7" Fill="#00FF88" VerticalAlignment="Center"
                                     Margin="0,0,7,0" Effect="{StaticResource GreenGlow}"/>
                            <TextBlock Text="STREAM ACTIF"
                                       Foreground="#00FF88" FontFamily="Consolas" FontSize="10"
                                       Effect="{StaticResource GreenGlow}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                            <Ellipse x:Name="PresentationStatusDot" Width="7" Height="7" Fill="#FF3060" VerticalAlignment="Center"
                                     Margin="0,0,7,0" Effect="{StaticResource RedGlow}"/>
                            <TextBlock x:Name="PresentationStatusText" Text="PRÉSENTATION INACTIVE"
                                       Foreground="#FF3060" FontFamily="Consolas" FontSize="10"
                                       Effect="{StaticResource RedGlow}"/>
                        </StackPanel>
                    </StackPanel>
                </Canvas>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="#05000010">
                <Rectangle Width="1" HorizontalAlignment="Right" Fill="#00FFFF" Opacity="0.12"/>
                <Canvas Width="160">
                    <Rectangle Canvas.Left="12" Canvas.Top="12" Width="2"  Height="20" Fill="#00FFFF" Opacity="0.55"/>
                    <Rectangle Canvas.Left="12" Canvas.Top="12" Width="20" Height="2"  Fill="#00FFFF" Opacity="0.55"/>
                    <TextBlock Canvas.Left="18" Canvas.Top="22" Text="RGB  ·  DEPTH"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="9" Opacity="0.45"/>

                    <TextBlock x:Name="FpsCounterText" Canvas.Left="18" Canvas.Top="35" Text="FPS  ·  0"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="9" Opacity="0.35"/>

                    <TextBlock x:Name="SlideLabel" Canvas.Left="14" Canvas.Top="490" Text="SLIDE" Visibility="Collapsed"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="12" Opacity="0.45"/>
                    <TextBlock x:Name="SlideCounterText"
                               Visibility="Collapsed"
                               Canvas.Left="28" Canvas.Top="510"
                               Text="1 / 8"
                               Foreground="#00FFFF" FontFamily="Consolas"
                               FontSize="42" FontWeight="Bold"
                               Effect="{StaticResource NeonGlow}"/>

                    <Rectangle Canvas.Left="12" Canvas.Top="568" Width="2"  Height="20" Fill="#00FFFF" Opacity="0.55"/>
                    <Rectangle Canvas.Left="12" Canvas.Top="586" Width="20" Height="2"  Fill="#00FFFF" Opacity="0.55"/>
                </Canvas>
            </Grid>

            <Grid Grid.Column="1">
                <Viewbox Stretch="Uniform">
                    <Grid Width="640" Height="480">
                        <Image x:Name="CameraBackground" Stretch="Fill"/>
                        <Canvas x:Name="DrawingCanvas" Background="Transparent" IsHitTestVisible="False"/>
                        <Canvas x:Name="OverlayCanvas"  IsHitTestVisible="False"/>
                    </Grid>
                </Viewbox>

                <Rectangle IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <DrawingBrush TileMode="Tile" Viewport="0,0,4,4" ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,4,1"/>
                                    </GeometryDrawing.Geometry>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="Black" Opacity="0.18"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid x:Name="PptSlidePanel"
                      Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      MaxWidth="920" MaxHeight="560">
                    <Grid.Effect>
                        <DropShadowEffect BlurRadius="40" Color="Black" Opacity="0.92" ShadowDepth="10"/>
                    </Grid.Effect>
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="PptScale"     ScaleX="1" ScaleY="1" CenterX="460" CenterY="280"/>
                            <TranslateTransform x:Name="PptTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>
                    <Image x:Name="SlideImageA" Stretch="Uniform"/>
                    <Image x:Name="SlideImageB" Stretch="Uniform" Opacity="0"/>
                    <Border x:Name="PptSelectionBorder" BorderBrush="White" BorderThickness="0" CornerRadius="2">
                        <Border.Effect>
                            <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                        </Border.Effect>
                    </Border>
                </Grid>

                <StackPanel x:Name="OpenPptPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <Button x:Name="BtnOpenPpt"
                            Style="{StaticResource FuturisticButton}"
                            Click="BtnOpenPpt_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="BtnIcon" Text="●  " Foreground="#FF00FF" Effect="{StaticResource MagentaGlow}"/>
                            <TextBlock x:Name="BtnText"
                                       Text="📊  OUVRIR POWERPOINT"
                                       FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Column="2" Background="#05000010">
                <Rectangle Width="1" HorizontalAlignment="Left" Fill="#00FFFF" Opacity="0.12"/>
                <Canvas Width="160">
                    <Rectangle Canvas.Right="12" Canvas.Top="12" Width="2"  Height="20" Fill="#00FFFF" Opacity="0.55"/>
                    <Rectangle Canvas.Right="12" Canvas.Top="12" Width="20" Height="2"  Fill="#00FFFF" Opacity="0.55"/>
                    <TextBlock Canvas.Right="18" Canvas.Top="22" Text="REALSENSE"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="9" Opacity="0.45"/>
                    <TextBlock Canvas.Right="18" Canvas.Top="490" Text="DEPTH"
                               Foreground="#00FFFF" FontFamily="Consolas" FontSize="9" Opacity="0.45"/>
                    <Rectangle Canvas.Right="12" Canvas.Top="568" Width="2"  Height="20" Fill="#00FFFF" Opacity="0.55"/>
                    <Rectangle Canvas.Right="12" Canvas.Top="586" Width="20" Height="2"  Fill="#00FFFF" Opacity="0.55"/>
                </Canvas>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="#0A000D18"
                BorderBrush="#1A00FFFF"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="6" Height="6" Fill="#00FF88" VerticalAlignment="Center"
                                 Margin="0,0,7,0" Effect="{StaticResource GreenGlow}"/>
                        <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#00FF88">
                            <Run Text="MAIN GAUCHE OUVERTE : "/>
                            <Run Text="CHANGER DIAPOSITIVE" Foreground="#FF00FF"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="6" Height="6" Fill="#00FF88" VerticalAlignment="Center"
                                 Margin="0,0,7,0" Effect="{StaticResource GreenGlow}"/>
                        <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#00FF88">
                            <Run Text="MAIN DROITE : "/>
                            <Run Text="ZOOM / DÉPLACEMENT / SÉLECTION" Foreground="#FF00FF"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#00FF88" VerticalAlignment="Center"
                                 Margin="0,0,7,0" Effect="{StaticResource GreenGlow}"/>
                        <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#00FF88">
                            <Run Text="2 MAINS OUVERTES 1.5s = "/>
                            <Run Text="QUITTER PRÉSENTATION" Foreground="#FF00FF"/>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="BtnClosePpt"
                        Style="{StaticResource CloseButton}"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Click="BtnClosePpt_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕  " Foreground="#FF3060" FontFamily="Consolas" FontSize="13"/>
                        <TextBlock Text="FERMER LA PRÉSENTATION"
                                   Foreground="#FF3060" FontFamily="Consolas" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#3A3A55" HorizontalAlignment="Right">
                        <Run Text="◈  INTEL REALSENSE D455"/>
                    </TextBlock>
                    <TextBlock FontFamily="Consolas" FontSize="9" Foreground="#2D2D44" HorizontalAlignment="Right" Margin="0,2,0,2">
                        <Run Text="DEPTH  ·  EXPLOSION"/>
                    </TextBlock>
                    <TextBlock FontFamily="Consolas" FontSize="9" Foreground="#3A3A55" HorizontalAlignment="Right">
                        <Run Text="GESTURE ENGINE V2.0"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>