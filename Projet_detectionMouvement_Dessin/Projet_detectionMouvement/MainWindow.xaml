<Window x:Class="Projet_detectionMouvement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Detection de mouvement — Dessin gestuel"
        Height="600" Width="680"
        Background="#1a1a2e"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="10,10,10,5"
                BorderBrush="#444466"
                BorderThickness="2"
                CornerRadius="4">

            <Viewbox Stretch="Uniform">
                <Grid Width="640" Height="480" ClipToBounds="True">

                    <Canvas Name="DrawingCanvas"
                            Background="#0d0d1a"/>

                    <Canvas Name="OverlayCanvas"
                            IsHitTestVisible="False"/>

                </Grid>
            </Viewbox>
        </Border>

        <Border Grid.Row="1"
                Background="#16213e"
                BorderBrush="#444466"
                BorderThickness="0,1,0,0">

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Ellipse Name="StatusDot"
                             Width="14" Height="14"
                             Fill="Gray"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>

                    <TextBlock Name="StatusText"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Text="En attente de connexion..."/>
                </StackPanel>

                <TextBlock Name="ToolText"
                           Grid.Column="1"
                           FontSize="13"
                           Foreground="LightGray"
                           VerticalAlignment="Center"
                           Text="● Rouge  taille 5"/>

            </Grid>
        </Border>
    </Grid>
</Window>