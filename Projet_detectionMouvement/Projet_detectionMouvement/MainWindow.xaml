<Window x:Class="Projet_detectionMouvement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Detection de mouvement — Intel RealSense D455"
        Height="590" Width="680"
        Background="#1a1a2e"
        ResizeMode="CanMinimize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Camera overlay canvas (640x480) -->
        <Border Grid.Row="0"
                Margin="10,10,10,5"
                BorderBrush="#444466"
                BorderThickness="2"
                CornerRadius="4">
            <Canvas Name="OverlayCanvas"
                    Width="640" Height="480"
                    Background="#0d0d1a"
                    ClipToBounds="True"/>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="#16213e"
                BorderBrush="#444466"
                BorderThickness="0,1,0,0"
                Margin="0">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="14,0">
                <!-- Indicator dot -->
                <Ellipse Name="StatusDot"
                         Width="14" Height="14"
                         Fill="Gray"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"/>
                <TextBlock Name="StatusText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Text="En attente de connexion..."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
